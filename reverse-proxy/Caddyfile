	encode gzip zstd

	handle /api/* {
		reverse_proxy callitcureit-tst-backend:8080
	}

	handle {
		reverse_proxy callitcureit-tst-frontend:80
	}
}

app.callitcureit.com {
	encode gzip zstd

	handle /api/* {
		reverse_proxy callitcureit-prd-backend:8080
	}

	handle {
		reverse_proxy callitcureit-prd-frontend:80
	}
}