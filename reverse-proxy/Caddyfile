dev.callitcureit.com {
	encode gzip zstd

	handle /api/* {
		header X-CIC-Route "dev-api"
		reverse_proxy callitcureit-dev-backend:8080
	}

	handle {
		reverse_proxy callitcureit-dev-frontend:80
	}
}

